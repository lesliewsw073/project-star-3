[gd_resource type="Resource" script_class="InteractionEventResource" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/resources/InteractionEventResource.gd" id="1_event"]
[ext_resource type="Script" path="res://scripts/resources/dialogue_line.gd" id="2_line"]
[ext_resource type="Script" path="res://scripts/resources/dialogue_sequence.gd" id="3_seq"]

[sub_resource type="Resource" id="line_1"]
script = ExtResource("2_line")
speaker_id = "protagonist"
text = "先不提蛋糕，说正事。今天不仅是正式欢迎你，也是我们的第一个周日例会。我看了你这周报上来的私教课和加练打卡，时间全塞满了。"

[sub_resource type="Resource" id="line_2"]
script = ExtResource("2_line")
speaker_id = "protagonist"
text = "公司目前确实只有你一个艺人，但这反而是优势。这意味着公司所有的资源、宣发和预算费用都会100%优先砸在你身上。我们有能力帮你对接最顶级的专业课程和通告，你没必要事事都自己生抗。"

[sub_resource type="Resource" id="line_3"]
script = ExtResource("2_line")
speaker_id = "protagonist"
text = "成果由我们一起拿。要是你先在排练室里累倒了，那公司可就彻底停摆了。你要做的是在通告和官方训练里全力以赴，而不是下了班还去连轴转。听我的，把私下的自我加练强度降一降。"

[sub_resource type="Resource" id="line_4"]
script = ExtResource("2_line")
speaker_id = "protagonist"
text = "这就对了，身体才是核心资产。那接下来，我们来对一下你下周的正式行程规划。"


[sub_resource type="Resource" id="dialogue"]
script = ExtResource("3_seq")
lines = Array[ExtResource("2_line")]([SubResource("line_1"), SubResource("line_2"), SubResource("line_3"), SubResource("line_4")])

[resource]
is_test_content = false
script = ExtResource("1_event")
event_id = "story_meeting_artist_003_first_session_01"
event_title = "周日迎新与正式会议"
interaction_type = 3
character_id = "artist_003"
execute_once = true
arc_type = 1
owner = "artist_003"
story_channel = 3
meeting_scope = "first"
dialogue = SubResource("dialogue")
blocking = true
required_flags = {"opening_pick": "artist_003", "sign_artist_003_done": true}
flag_changes = {"first_meeting_artist_003_done": true, "meeting.first_session_done": true}
priority = 200
