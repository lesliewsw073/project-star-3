GameFlowManager="*res://scripts/autoload/GameFlowManager.gd"
InventoryManager="*res://scripts/managers/InventoryManager.gd"
ItemDatabase="*res://scripts/autoload/ItemDatabase.gd"
CompanyItemManager="*res://scripts/managers/CompanyItemManager.gd"
PlayerHomeManager="*res://scripts/managers/PlayerHomeManager.gd"
