; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project_Star_3"
run/main_scene="res://GameRoot.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

TimeManager="*res://scripts/autoload/TimeManager.gd"
ArtistManager="*uid://crgjr1qyveniy"
RivalManager="*res://scripts/autoload/RivalManager.gd"
NpcManager="*res://scripts/autoload/NpcManager.gd"
ScheduleManager="*res://scripts/managers/ScheduleManager.gd"
FollowPlanManager="*res://scripts/managers/FollowPlanManager.gd"
PlayerManager="*uid://dr5bagpioo17l"
ProtagonistManager="*res://scripts/autoload/ProtagonistManager.gd"
DialogueVariableResolver="*res://scripts/autoload/DialogueVariableResolver.gd"
RelationshipManager="*res://scripts/autoload/RelationshipManager.gd"
CharacterDatabase="*res://scripts/autoload/CharacterDatabase.gd"
InteractionManager="*res://scripts/autoload/InteractionManager.gd"
StoryTriggerManager="*res://scripts/managers/StoryTriggerManager.gd"
StoryPlaybackController="*res://scripts/managers/StoryPlaybackController.gd"
CompanyDatabase="*uid://bwogr4yxelufc"
AgencyDatabase="*res://scripts/autoload/AgencyDatabase.gd"
JobManager="*res://scripts/autoload/JobManager.gd"
CourseManager="*res://scripts/autoload/CourseManager.gd"
